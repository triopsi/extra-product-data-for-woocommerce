{
  "name": "triopsi/extra-product-data-for-woocommerce",
  "homepage": "https://triopsi.com",
  "type": "project",
  "version": "3.3.0",
  "autoload": {
    "psr-4": {
      "Triopsi\\Exprdawc\\": "src/",
      "Triopsi\\Exprdawc\\Core\\": "src/Core/",
      "Triopsi\\Exprdawc\\Backend\\": "src/Backend/",
      "Triopsi\\Exprdawc\\Frontend\\": "src/Frontend/",
      "Triopsi\\Exprdawc\\Settings\\": "src/Settings/",
      "Triopsi\\Exprdawc\\Template\\": "src/Template/",
      "Triopsi\\Exprdawc\\Traits\\": "src/Traits/",
      "Triopsi\\Exprdawc\\Models\\": "src/Models/",
      "Triopsi\\Exprdawc\\Helpers\\": "src/Helpers/",
      "Triopsi\\Exprdawc\\Orders\\": "src/Orders/",
      "Triopsi\\Exprdawc\\Contracts\\": "src/Contracts/"
    }
  },
  "authors": [
    {
      "name": "Daniel Drevermann",
      "email": "daniel@triopsi.com"
    }
  ],
  "scripts": {
    "test": "phpunit --testdox",
    "test-cov": "XDEBUG_MODE=coverage phpunit --coverage-html=reports/coverage --coverage-clover=reports/clover.xml --testdox",
    "test-install": "bash bin/install-wp-tests.sh wordpress_test root 'root' db latest"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "platform": {
      "php": "8.4.1"
    }
  },
  "require": {
    "php": ">=8.0"
  },
  "require-dev": {
    "wp-coding-standards/wpcs": "^3.0",
    "squizlabs/php_codesniffer": "^3.13.5",
    "dealerdirect/phpcodesniffer-composer-installer": "1.2.1",
    "phpcompatibility/phpcompatibility-wp": "*",
    "wp-phpunit/wp-phpunit": "^6.9",
    "phpunit/phpunit": "^13.1",
    "php-stubs/woocommerce-stubs": "^10.5"
  }
}
